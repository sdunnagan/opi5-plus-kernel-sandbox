[Unit]
Description=OPi5+ kernel sandbox
After=systemd-modules-load.service
Wants=systemd-modules-load.service
After=dev-gpiochip1.device
Wants=dev-gpiochip1.device

[Service]
Type=simple
ExecStart=/usr/local/libexec/opi5-sandbox-start.sh
Restart=on-failure
RestartSec=1
User=root
Group=root

[Install]
WantedBy=multi-user.target
